package pkg033_computadorpensa;

import java.util.Random;
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        
        Random random = new Random();
        int numeroPensado = random.nextInt(5) + 1; // número entre 1 e 5

        Scanner scanner = new Scanner(System.in);

        System.out.println("Tente adivinhar o número que estou pensando (de 1 a 5): ");
        int palpite = scanner.nextInt();

        if (palpite == numeroPensado) {
            System.out.println("Parabéns! Você acertou.");
        } else {
            System.out.println("Você errou. Eu estava pensando no número " + numeroPensado + ".");
        }

        scanner.close();
    }
}
