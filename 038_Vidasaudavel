package pkg038_vidasaudavel;

import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Entrada de dados
        System.out.print("Quantas horas de atividade física você fez este mês? ");
        double horas = scanner.nextDouble();

        int pontos = 0;

        // Cálculo de pontos com base nas horas
        if (horas <= 10) {
            pontos = (int)(horas * 2);
        } else if (horas <= 20) {
            pontos = (int)(horas * 5);
        } else {
            pontos = (int)(horas * 10);
        }

        // Cálculo do valor em dinheiro
        double dinheiro = pontos * 0.05;

        // Resultado
        System.out.println("Você ganhou " + pontos + " pontos.");
        System.out.printf("Você faturou R$ %.2f\n", dinheiro);

        scanner.close(); 
    }
    
}
